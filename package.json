{
  "name": "intent-compiler-agent",
  "version": "0.1.0",
  "description": "Open-source Intent Compiler Agent that compresses messy prompts into structured intent and minimal AI-ready instructions.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "skill": "node skills/intent-compiler/scripts/compile-intent.js",
    "skill:codex": "node skills/intent-compiler/scripts/compile-intent.js"
  },
  "keywords": [
    "ai",
    "agent",
    "prompt-compression",
    "intent-compiler",
    "open-source"
  ],
  "author": "Yakhanani Maswana",
  "license": "MIT",
  "dependencies": {
    "dotenv": "latest",
    "openai": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
